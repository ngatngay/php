{
    "name": "ngatngay/ngatngay",
    "description": "ngatngay php pro max",
    "authors": [
        {
            "name": "ngatngay",
            "email": "ngatngay@ngatngay.net"
        }
    ],
    "require": {
        "php": ">=7.4",
        "symfony/cache": "*",
        "php-curl-class/php-curl-class": "^11.0",
        "symfony/var-dumper": "*"
    },
    "autoload": {
        "psr-4": {
            "NgatNgay\\": "src/"
        },
        "files": [
            "src/function.php"
        ]
    },
    "config": {    
        "sort-packages": true,
        "platform": {
            "php": "7.4"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "^1.23"
    }
}
