{
    "name": "ngatngay/ngatngay",
    "description": "ngatngay pro max",
    "require": {
        "php": ">=8.2.0",
        "php-curl-class/php-curl-class": ">=12.0",
        "symfony/browser-kit": ">=6.4",
        "symfony/cache": ">=6.4",
        "symfony/http-client": ">=6.4",
        "symfony/var-dumper": ">=6.4",
        "symfony/yaml": ">=6.4"
    },
    "autoload": {
        "psr-4": {
            "ngatngay\\": "src/"
        },
        "files": [
            "src/function.php"
        ]
    },
    "config": {    
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "^3.8"
    }
}
