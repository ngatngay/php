{
    "name": "ngatngay/ngatngay",
    "description": "ngatngay pro max",
    "require": {
        "php": ">=7.4",
        "php-curl-class/php-curl-class": "^11.0",
        "symfony/browser-kit": ">=5.4",
        "symfony/cache": ">=5.4",
        "symfony/http-client": ">=5.4",
        "symfony/var-dumper": ">=5.4",
        "symfony/yaml": ">=5.4"
    },
    "autoload": {
        "psr-4": {
            "ngatngay\\": "src/"
        },
        "files": [
            "src/function.php"
        ]
    },
    "config": {    
        "sort-packages": true,
        "platform": {
            "php": "7.4"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "^1.23"
    }
}
